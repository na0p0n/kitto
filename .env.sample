# =============================================================
# Kitto - 環境変数サンプル
# このファイルをコピーして .env を作成し、サーバーに配置してください
# cp .env.sample .env
# =============================================================

# -------------------------------------------------------------
# Backend
# -------------------------------------------------------------

# フロントエンドのオリジン（CORS許可対象）
# 複数ある場合はカンマ区切り: https://example.com,https://www.example.com
KITTO_CORS_ALLOWED_ORIGINS=https://your-domain.com

# -------------------------------------------------------------
# Docker Compose - イメージ・ポートマッピング
# -------------------------------------------------------------

# 使用するイメージタグ（dev / latest / v1.0.0 など）
IMAGE_TAG=latest

# バックエンドのホスト側ポート（コンテナ内は常に8080）
BACKEND_PORT=8081

# フロントエンドのホスト側ポート
FRONTEND_PORT=3000

# -------------------------------------------------------------
# Note: NEXT_PUBLIC_API_URL について
# -------------------------------------------------------------
# Next.js の NEXT_PUBLIC_* 変数はビルド時にバンドルへ埋め込まれます。
# そのため、この値は CI（GitHub Actions）側で GitHub Variables として
# 設定する必要があります。
#
# GitHub リポジトリ Settings → Secrets and variables → Actions → Variables:
#   DEV_NEXT_PUBLIC_API_URL  = https://dev.your-domain.com:8081
#   PROD_NEXT_PUBLIC_API_URL = https://your-domain.com:8081
#
# nginx でリバースプロキシしている場合は例:
#   PROD_NEXT_PUBLIC_API_URL = https://your-domain.com/api
